---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
---

<BaseLayout title="Thanks | Tom Woodhouse" description="Thanks for requesting a free review.">
  <main class="page">
    <SiteNav />

    <section class="section thanks">
      <div>
        <p class="eyebrow">Review request sent</p>
        <h1>Thanks for reaching out.</h1>
        <p class="body">
          I have your details and will reply within 48 hours with the best next step. If you need
          to add anything, email <a href="mailto:hello@tom-woodhouse.com">hello@tom-woodhouse.com</a>.
        </p>
        <a class="btn primary" href="/#products">Back to products</a>
      </div>
    </section>
  </main>
</BaseLayout>
