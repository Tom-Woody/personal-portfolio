---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import ReviewForm from "../components/ReviewForm.astro";
import { productSummaries } from "../data/products";
import tomPortrait from "../assets/tom-woodhouse.jpeg";
import yumiNutrition from "../assets/yumi-nutrition.png";
import fixMyBrokenMac from "../assets/fmbm.jpg";
import wolffLaundry from "../assets/wolf.png";
import dabbaDrop from "../assets/Dabba.png";

const stats = [
  { label: "Years of experience", value: "11" },
  { label: "Focus", value: "CRO + automation" },
  { label: "Platforms", value: "Shopify, WordPress + ops" },
];

const projects = [
  {
    name: "Yumi Nutrition",
    description: "Shopify Plus development for a fast-growing nutrition brand.",
    result: "Shopify Plus development",
    image: yumiNutrition,
  },
  {
    name: "Fix My Broken Mac",
    description: "Conversion-focused site refresh for a repair service brand.",
    result: "WordPress development",
    image: fixMyBrokenMac,
  },
  {
    name: "Wolff Laundry",
    description: "WooCommerce development for a streamlined ecommerce experience.",
    result: "WooCommerce development",
    image: wolffLaundry,
  },
  {
    name: "DabbaDrop",
    description: "Shopify development for an optimized, responsive storefront.",
    result: "Shopify development",
    image: dabbaDrop,
  },
];

const services = [
  {
    title: "Conversion-led websites",
    detail: "Builds and redesigns that make your offer clearer, your journey smoother, and your site easier to trust.",
  },
  {
    title: "Lead follow-up systems",
    detail: "Simple systems that capture, track, and chase enquiries so revenue does not rely on memory.",
  },
  {
    title: "AI automation sprints",
    detail: "Focused workflow automations that cut repetitive admin without turning into a huge software project.",
  },
];

const process = [
  {
    step: "01",
    title: "Review the bottleneck",
    detail: "We look at where the revenue leak, manual admin, or conversion friction is happening now.",
  },
  {
    step: "02",
    title: "Choose the right sprint",
    detail: "We scope the fastest productised offer or build sprint that will create a meaningful result.",
  },
  {
    step: "03",
    title: "Build the fix",
    detail: "I implement the pages, follow-up flow, or automation with clarity, performance, and usability in mind.",
  },
  {
    step: "04",
    title: "Launch and hand over",
    detail: "Everything is tested, documented, and handed over cleanly so the result is usable from day one.",
  },
];

const stack = ["Shopify", "Shopify Plus", "WordPress", "WooCommerce", "CRO", "Automation", "Performance"];
---

<BaseLayout
  title="Tom Woodhouse - Websites, Follow-Up Systems & Automation"
  description="Websites, follow-up systems, and automations that turn interest into revenue."
>
  <main class="page">
    <SiteNav />
    <header class="hero">
      <div class="hero__content">
        <p class="eyebrow">Freelance Web Developer - CRO Consultant</p>
        <h1>Websites, follow-up systems, and automations that turn interest into revenue.</h1>
        <p class="lead">
          I help small businesses fix the digital systems behind their website, enquiries,
          follow-up, and admin so fewer leads slip through and less time is lost to manual work.
        </p>
        <div class="hero__actions">
          <a class="btn primary" href="/free-review">Get a free review</a>
          <a class="btn ghost" href="/#work">View work</a>
        </div>
        <div class="hero__stats">
          {stats.map((stat) => (
            <div class="stat">
              <span>{stat.value}</span>
              <p>{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__portrait">
          <img src={tomPortrait.src} alt="Portrait of Tom Woodhouse" loading="eager" />
        </div>
        <div class="card">
          <p>Availability - Taking on new work</p>
          <h3>Website projects, audits, and automation sprints</h3>
          <div class="pulse">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
        <div class="orbit">
          <div class="orb orb--lg"></div>
          <div class="orb orb--md"></div>
          <div class="orb orb--sm"></div>
        </div>
      </div>
    </header>

    <section class="marquee" aria-label="Platforms and focus areas">
      <div class="marquee__inner">
        <span>Shopify</span>
        <span>Shopify Plus</span>
        <span>WooCommerce</span>
        <span>WordPress</span>
        <span>Conversion Rate Optimization</span>
        <span>Performance</span>
        <span>Shopify</span>
        <span>Shopify Plus</span>
      </div>
    </section>

    <section class="section" id="work">
      <div class="section__title">
        <p class="eyebrow">Latest work</p>
        <h2>Recent projects focused on performance and conversions.</h2>
      </div>
      <div class="grid">
        {projects.map((project) => (
          <article class="project-card">
            {project.image && (
              <div class="project-card__media">
                <img src={project.image.src} alt={`${project.name} preview`} loading="lazy" />
              </div>
            )}
            <h3>{project.name}</h3>
            <p>{project.description}</p>
            <span>{project.result}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="products">
      <div class="section__title">
        <p class="eyebrow">Productised services</p>
        <h2>Focused offers for the revenue leaks and admin bottlenecks that keep showing up.</h2>
      </div>
      <div class="grid">
        {productSummaries.map((product) => (
          <article class="project-card product-card">
            <div class="product-card__meta">
              <span class="chip">Fixed-scope offer</span>
            </div>
            <h3>{product.name}</h3>
            <p>{product.description}</p>
            <a class="btn ghost product-card__cta" href={product.href}>
              {product.ctaLabel}
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="section section--split" id="services">
      <div>
        <p class="eyebrow">Ways I can help</p>
        <h2>Web, CRO, and automation support built around commercial outcomes.</h2>
        <p class="body">
          I work with founders and small teams who want the front end and back end of the customer
          journey to work together more cleanly.
        </p>
      </div>
      <div class="stack">
        {services.map((service) => (
          <div class="service">
            <h3>{service.title}</h3>
            <p>{service.detail}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section section--split" id="process">
      <div>
        <p class="eyebrow">Process</p>
        <h2>A streamlined process from discovery to launch.</h2>
        <p class="body">
          Clear steps, fast feedback, and measurable outcomes at every stage.
        </p>
        <div class="stack chips">
          {stack.map((item) => (
            <span class="chip">{item}</span>
          ))}
        </div>
      </div>
      <div class="stack process">
        {process.map((item) => (
          <div class="service">
            <span class="step">{item.step}</span>
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section testimonials">
      <div>
        <p class="eyebrow">Client testimonials</p>
        <h2>"Tom is a fantastic developer. We would recommend using him again."</h2>
      </div>
      <div class="quote">
        <p>
          "Overall Tom was a pleasure to work with, communicated well, worked hard and we were
          left with a Shopify reskin which was almost identical to our mock ups for a very
          reasonable price."
        </p>
        <span>- Sean Knowles</span>
      </div>
    </section>

    <section class="section contact" id="contact">
      <div>
        <p class="eyebrow">Get a free review</p>
        <h2>Share what feels leaky, manual, or underperforming.</h2>
        <p class="body">
          I will review the context and point you toward the most useful next step, without forcing
          a phone call first.
        </p>
      </div>
      <ReviewForm />
    </section>

    <SiteFooter />
  </main>
</BaseLayout>
